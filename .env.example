# ── Optional: OpenSky Network (live flight tracking) ─────
# Register at https://opensky-network.org to get OAuth2 credentials.
# Without these, flights still work but with lower rate limits.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ── Optional: YouTube Data API v3 (trending videos) ──────
# Get a free API key at https://console.cloud.google.com
# Enable "YouTube Data API v3" in your project.
# Without this, the Media > Trending section shows a fallback message.
YOUTUBE_API_KEY=

# ── Optional: AISStream (live vessel tracking) ──────────
# Register at https://aisstream.io for a free API key.
# Without this, the vessel tracking layer on the transport map is hidden.
NEXT_PUBLIC_AISSTREAM_API_KEY=

# ── Optional: MET Malaysia (backup weather source) ────────
# Register at https://api.met.gov.my for a METToken.
# Not required — primary weather data comes from data.gov.my.
# MET_MALAYSIA_TOKEN=
